{
  "name": "hydro-js",
  "version": "1.9.0",
  "description": "A lightweight reactive library",
  "type": "module",
  "main": "./dist/library.js",
  "module": "./dist/library.js",
  "types": "./dist/library.d.ts",
  "exports": {
    ".": {
      "types": "./dist/library.d.ts",
      "default": "./dist/library.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "default": "./dist/jsx-dev-runtime.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "concurrently \"serve dist\" \"tsc -w\"",
    "test": "npm run test:dom && npm run test:browser",
    "test:dom": "node dist/testHAPPYDOM.js && node dist/testJSDOM.js",
    "test:browser": "tsc && wtr src/test.html --node-resolve --coverage --playwright --browsers chromium firefox webkit",
    "bench": "npm run bench:mem && npm run bench:perf && npm run bench:size",
    "bench:happy": "npm run bench:mem:happy",
    "bench:browser": "npm run bench:mem:browser",
    "bench:mem": "npm run bench:mem:happy && npm run bench:mem:browser",
    "bench:mem:happy": "tsc && node --expose-gc dist/benchmark.node.js",
    "bench:mem:browser": "tsc && wtr --config web-test-runner.bench.config.mjs",
    "bench:perf": "npm run bench:perf:happy && npm run bench:perf:browser",
    "bench:perf:happy": "tsc && node --expose-gc dist/benchmark.perf.node.js",
    "bench:perf:baseline": "tsc && node --expose-gc dist/benchmark.perf.node.js --write-baseline perf-baseline.json",
    "bench:perf:check": "tsc && node --expose-gc dist/benchmark.perf.node.js --baseline perf-baseline.json --max-regression-percent 15",
    "bench:perf:browser": "tsc && wtr --config web-test-runner.perf.config.mjs",
    "bench:size": "tsc && node dist/benchmark.size.node.js",
    "update": "npx npm-check-updates -u && npx typesync && npm i && npm outdated"
  },
  "keywords": [
    "reactive",
    "library",
    "javascript",
    "dom",
    "modern",
    "fast",
    "ssr"
  ],
  "author": "Fabian Klingenberg <klingenberg.fabian@gmx.de> (https://klingenberg.works/)",
  "license": "MIT",
  "devDependencies": {
    "@esm-bundle/chai": "^4.3.4",
    "@types/jsdom": "^28.0.1",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "concurrently": "^10.0.0",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.8.8",
    "jsdom": "^29.0.1",
    "serve": "^14.2.6",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krutsch/hydro-js.git"
  },
  "bugs": "https://github.com/Krutsch/hydro-js/issues",
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
